{
  "name": "team-applications-bot",
  "version": "1.0.0",
  "description": "Scalable Telegram bot for team applications",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
